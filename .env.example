# Variables de entorno (configúralas en Render, NO las subas a GitHub).
# En tu PC local NO hace falta nada de esto: usa archivos en data/.

# Clave privada para ver la bitácora
ADMIN_KEY=pon-aqui-tu-clave-secreta

# Supabase (Project Settings → API)
SUPABASE_URL=https://tuproyecto.supabase.co
SUPABASE_KEY=tu-clave-service_role-secreta

# --- Buscador (OPCIONAL) ---
# Apple funciona sin nada de esto. Para activar las pestañas de Spotify/YouTube
# en el buscador, agrega sus claves:

# Spotify (https://developer.spotify.com/dashboard → Create app)
# SPOTIFY_CLIENT_ID=tu-client-id
# SPOTIFY_CLIENT_SECRET=tu-client-secret

# YouTube (Google Cloud → API key con "YouTube Data API v3" habilitada)
# YOUTUBE_API_KEY=tu-api-key
